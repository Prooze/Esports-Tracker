# ─── Required ────────────────────────────────────────────────────────────────

# A long random secret for signing JWTs.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-secret


# ─── Optional ────────────────────────────────────────────────────────────────

# Server port (default 3001)
PORT=3001

# Allowed frontend origin in production (CORS allowlist).
# Localhost dev origin is always allowed.
CLIENT_ORIGIN=https://your-frontend.example.com

# SQLite database file location.
# Defaults to ./data/database.sqlite when unset.
# Railway: point this at a Volume mount (e.g. /app/data/database.sqlite).
DB_PATH=./data/database.sqlite

# First-boot admin credentials. If set, a superadmin is auto-created on the
# very first server start. Ignored if any admin account already exists.
# Alternative: run `node scripts/createFirstAdmin.js <user> <pass>` manually.
FIRST_ADMIN_USER=
FIRST_ADMIN_PASS=

# Cloudinary credentials (image hosting). Optional — when unset, uploaded
# images are stored locally under server/uploads/ instead.
# These can also be configured in the Admin → Integrations tab at runtime;
# DB-stored values take precedence over these env vars.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
